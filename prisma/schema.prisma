// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums
// Models
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String?
  role      String   @default("USER") // Was Role
  createdAt DateTime @default(now())
  
  spots               Spot[]
  favorites           Favorite[]
  checklistItems      ChecklistItem[]
  checklistCategories ChecklistCategory[]
  pernoctas           Pernocta[]
}

model Spot {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  latitude    Float
  longitude   Float
  isFree      Boolean  @default(true)
  places      Int      @default(1)
  category    String   // Was SpotCategory
  images      SpotImage[]
  services    SpotService[]
  rating      Int      @default(0)
  
  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])
  
  favoritedBy Favorite[]
  pernoctas   Pernocta[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SpotImage {
  id        Int      @id @default(autoincrement())
  url       String
  spotId    Int
  spot      Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
}

model Service {
  id    Int           @id @default(autoincrement())
  name  String        @unique
  icon  String        // Lucide icon name
  spots SpotService[]
}

model SpotService {
  spotId    Int
  serviceId Int
  spot      Spot    @relation(fields: [spotId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([spotId, serviceId])
}

model Favorite {
  userId Int
  spotId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot   Spot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@id([userId, spotId])
}

model ChecklistItem {
  id         Int                @id @default(autoincrement())
  text       String
  checked    Boolean            @default(false)
  type       String             // "FOOD" | "GEAR"
  userId     Int
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId Int?
  category   ChecklistCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime           @default(now())
}

model ChecklistCategory {
  id        Int             @id @default(autoincrement())
  name      String
  type      String          // "FOOD" | "GEAR"
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]
  createdAt DateTime        @default(now())
}

model Pernocta {
  id           Int      @id @default(autoincrement())
  date         DateTime
  latitude     Float
  longitude    Float
  notes        String?
  weather      String?
  cost         Float?   @default(0)
  locationName String?
  province     String?
  country      String?
  spotId       Int?
  spot         Spot?    @relation(fields: [spotId], references: [id], onDelete: SetNull)
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model ConfigurableList {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   @unique
  icon      String
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
